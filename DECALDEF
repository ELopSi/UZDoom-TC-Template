// DECALDEF is a script definition that specifies a texture or sprite to be 
// applied as a decal (e.g., bullet holes, blood splatters) on walls, floors, 
// or ceilings, including properties like size, orientation, and behavior.

// https://zdoom.org/w/index.php?title=DECALDEF

// Decal animation need to be define before they are called
fader FadeDecalAnimationTemplate
{
   DecayStart 0
   DecayTime 5
}

// Custom Decal 1 --------------
decal CustomDecal1 1	// Name and ID
{
	// Call the animation
	animator FadeDecalAnimationTemplate

    // The name of the graphic used by the decal. You can apply
	// the decal offset directly in the image editor
    pic DECAL1
	
    // The image will be shaded
    //shade "ff ff ff" 
	
    // Scaled to 2x of the image's original size
    x-scale 2
    y-scale 2
	
    // Will be randomly flipped along the X, or Y or both axes
    randomflipx
    randomflipy	
}

generator Rocket CustomDecal1

// Custom Decal 2 --------------

decal CustomDecal2 2
{
	animator FadeDecalAnimationTemplate

    pic DECAL2
	
    x-scale 0.1
    y-scale 0.1	
}

// Custom Decal 3 --------------

decal CustomBloodDecal 3
{
	pic BSPLD0
	
    x-scale 1
    y-scale 1
}

decal CustomBloodSplatterDecal1 4
{
	pic BSPLA0
	translucent 0.6
	
    x-scale 0.5
    y-scale 0.5
	
	randomflipx
    randomflipy		
}

decal CustomBloodSplatterDecal2 5
{
	pic BSPLB0
	translucent 0.6
	
	x-scale 0.5
    y-scale 0.5
	
	randomflipx
    randomflipy			
}

decal CustomBloodSplatterDecal3 5
{
	pic BSPLC0
	translucent 0.6
	
	x-scale 0.5
    y-scale 0.5
	
	randomflipx
    randomflipy		
}

decal CustomBloodSplatterDecal4 6
{
	pic BSPLD0
	translucent 0.6
	
    x-scale 0.5
    y-scale 0.5
	
	randomflipx
    randomflipy		
}

decalgroup CustomGroupBloodSplatterDecal 7
{
	CustomBloodSplatterDecal1 1
	CustomBloodSplatterDecal2 1
	CustomBloodSplatterDecal3 1
	CustomBloodSplatterDecal4 1
}

