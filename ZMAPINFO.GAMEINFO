// SpawnNums is a numeric ID used internally by the engine to spawn 
// an actor by number at runtime. It is not for map editors, that’s
// what DoomEdNum is for.

SpawnNums
{
	
}

DoomEdNums
{
	30000 = "Medal"
	30001 = "TemplateKey"
}