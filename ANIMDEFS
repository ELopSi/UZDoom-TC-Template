// Simple Switch with sound
switch SWH1 on sound SFX/SwitchTemplateOn pic SWH2 tics 0 off sound SFX/SwitchTemplateOff pic SWH1 tics 0

// Simple texture animations
texture WATER1 range WATER4 tics 8
texture	TOXIC1 range TOXIC4 rand 3 10	// allowdecals
	
// Easy Ripple Effects
warp texture RIPPLE1 //	allowdecals